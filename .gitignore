# Python virtual environments
.env
.venv/
venv/
/env/

# Python Cache
__pycache__/
*.pyc

# Local Databases (SQLite WAL mode)
*.db
*.db-wal
*.db-shm

# Logs
gexvex.log
*.log

# OS generated files
.DS_Store
Thumbs.db

# PDF files (source docs — large binaries, not tracked)
*.pdf

# Data directory (raw docs and extracted output)
data/
# Exception: sandbox/sira_configs/data/ holds SIRA hydra config files,
# not corpus data. The bare `data/` pattern above was matching it.
!sandbox/sira_configs/data/
!sandbox/sira_configs/data/**

# Extracted images (byproduct of PDF extraction)
extracted_images/

# HuggingFace model cache tarballs — too large for the repo (80 MB+);
# pulled via the standard HF download path on first use.
assets/hf_cache/

# Pytest
.pytest_cache/

#git-sync files
git-sync/

# Local environment definitions (keep .gitkeep only)
environments/*.json
# customizations/mappings/ is NOT gitignored [D-062]:
# the directory carries proprietary mapping snapshots that DO get
# committed + pushed to the company-internal git remote (so team
# members share a single source of truth). Public-mirror leak is
# prevented by the work-PC pre-push hook installed by
# ~/work/utils/git-sync/sync-work.sh — it blocks any push whose
# remote URL points at github.com unless NORA_ALLOW_PUBLIC_PUSH=1.


# Vim swap files
*.swp
*.swo
.claude/scheduled_tasks.lock

# COMPACT per-clone session binding (do not commit)
.compact/

# Sandbox area for third-party tools (sira/ strand and similar).
# Cloned upstream repos are unversioned here so we can `git pull` them
# independently of NORA's history. Glue we write (adapters, shims,
# run notes) lives in subdirs of sandbox/ that AREN'T under sandbox/sira/.
sandbox/sira/
