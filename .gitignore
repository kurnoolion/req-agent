# Python virtual environments
.env
.venv/
venv/
/env/

# Python Cache
__pycache__/
*.pyc

# Local Databases (SQLite WAL mode)
*.db
*.db-wal
*.db-shm

# Logs
gexvex.log
*.log

# OS generated files
.DS_Store
Thumbs.db

# PDF files (source docs — large binaries, not tracked)
*.pdf

# Data directory (raw docs and extracted output)
data/

# Extracted images (byproduct of PDF extraction)
extracted_images/

# Pytest
.pytest_cache/

#git-sync files
git-sync/

# Local environment definitions (keep .gitkeep only)
environments/*.json

# Per-bootstrap mapping snapshots (D-062). Owned by Cline. Keys
# proprietary placeholders to real MNO / plan / release values; must
# never reach the public mirror. Keep .gitkeep + README.
customizations/mappings/*
!customizations/mappings/.gitkeep
!customizations/mappings/README.md


# Vim swap files
*.swp
*.swo
.claude/scheduled_tasks.lock
